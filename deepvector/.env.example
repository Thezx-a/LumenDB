# DeepVector Agent — environment template (copy to .env, never commit .env)
# 免费资源说明 / Free tier guide: course/FREE_RESOURCES_zh.md

# --- DeepVector C++ server ---
AGENTICDB_DEEPVECTOR_URL=http://127.0.0.1:8080

# --- Embedding (recommended: local, free, 384-d) ---
AGENTICDB_EMBEDDING_PROVIDER=local
AGENTICDB_EMBEDDING_MODEL=all-MiniLM-L6-v2
# HF mirror (optional, China): HF_ENDPOINT=https://hf-mirror.com

# --- Option A: Ollama (fully free, default) ---
AGENTICDB_LLM_PROVIDER=ollama
AGENTICDB_LLM_MODEL=qwen2.5:7b
AGENTICDB_OLLAMA_HOST=http://localhost:11434

# --- Option B: ModelScope (~2000 free calls/day) ---
# AGENTICDB_LLM_PROVIDER=openai
# OPENAI_API_KEY=ms-your-token
# OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1/
# AGENTICDB_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Option C: SiliconFlow (https://siliconflow.cn) ---
# AGENTICDB_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-siliconflow-key
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# AGENTICDB_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Option D: Groq (https://console.groq.com) ---
# AGENTICDB_LLM_PROVIDER=openai
# OPENAI_API_KEY=gsk_your-groq-key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# AGENTICDB_LLM_MODEL=llama-3.3-70b-versatile

# --- Option E: AIHubmix (Hello-Agents Extra07) ---
# AGENTICDB_LLM_PROVIDER=openai
# OPENAI_API_KEY=your-aihubmix-key
# OPENAI_BASE_URL=https://aihubmix.com/v1
# AGENTICDB_LLM_MODEL=coding-glm-4.7-free

# --- Option F: OpenRouter free models (model id must end with :free) ---
# AGENTICDB_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-or-your-key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# AGENTICDB_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
