# =========================
# TitanKV .gitignore
# =========================

# ---- C++ build artifacts ----
build/
**/build/
cmake-build-*/
CMakeFiles/
cmake_install.cmake
*.dir/
*.vcxproj*
*.sln
*.tlog/
*.obj
*.o
*.so
*.a
_deps/

# Storage engine data (local test runs)
# 注意: 用 /data/ 只忽略项目根目录的 data/, 不要影响 services/data/ 等子目录
/data/
*.sst
*.log
*.bin
MANIFEST-*
*.wal
CURRENT
LOCK

# ---- Go ----
bin/
*.exe
*.test
*.out
coverage.out
vendor/

# ---- Node / Next.js ----
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo

# ---- Python (compat) ----
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Env / Secrets ----
.env
.env.local
*.pem
*.key

# ---- Docker local volumes ----
.docker/
deploy/dev/volumes/